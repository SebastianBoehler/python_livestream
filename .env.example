# YouTube Stream Configuration
YOUTUBE_STREAM_KEY=your-stream-key-here
URL_TO_CAPTURE=https://www.example.com

# Stream Settings (Optimized for data flow)
FPS=30                    # Standard framerate
VIDEO_BITRATE=2500k      # Increased bitrate for more data flow
BUFFER_SIZE=12000k       # Significantly increased buffer size
THREAD_QUEUE_SIZE=4096   # Larger queue for data processing

# Advanced Stream Settings
PRESET=ultrafast         # Fastest encoding preset
KEYFRAME_INTERVAL=60     # Keyframe every 2 seconds
RC_LOOKAHEAD=20         # Reduced lookahead for faster processing
TUNE_ZEROLATENCY=true   # Optimize for streaming
PROFILE=baseline        # Simpler profile for faster processing

# Overlay Settings
OVERLAY_TEXT=🔴 Live: Trading Stream
